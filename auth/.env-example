MODE=DEV

DB_HOST=db_auth_service_doc
DB_PORT=1224
DB_USER=postgres
DB_PASS=postgres
DB_NAME=auth_doc_db

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=put_fernet_key_here

DEFAULT_LOGIN=admin
DEFAULT_PASSWORD=change_me

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=21
MAX_REFRESH_SESSIONS=5
ALGORITHM=HS256
PUBLIC_KEY=dev-local-jwt-secret
PRIVATE_KEY=dev-local-jwt-secret

POSTGRES_DB=auth_doc_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
